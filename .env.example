# Database Configuration
DATABASE_NAME=dicoevent_production
DATABASE_USER=dicoevent_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Django Settings
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_HOURS=3

# Newman / Postman helpers
# The wrapper script uses these defaults when running the collection locally.
POSTMAN_HOST=localhost
POSTMAN_PORT=8000

# The Postman collection asserts a fixed username after the user-update step.
# Keep this aligned with the Postman environment unless you intentionally
# override it when invoking scripts/run_newman.py.
NEW_USERNAME=DicodingIndonesia
